generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= USER =============
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  passwordHash     String?

  googleId         String?   @unique
  authProvider     String    @default("email")

  firstName        String?
  lastName         String?
  phone            String?
  country          String?   @default("CM")
  city             String?
  avatarUrl        String?
  bio              String?

  language         String    @default("fr")
  timezone         String?
  notificationPrefs Json?    @map("notification_prefs")
  role             String?   @default("user")
  isBlocked        Boolean   @default(false)
  blockedAt        DateTime?

  twoFactorEnabled Boolean   @default(false)
  onboardingCompleted Boolean @default(false)

  shops            Shop[]
  sessions         Session[]
  trustedDevices   TrustedDevice[]
  supportTickets   SupportTicket[]  @relation("TicketOwner")
  supportMessages  SupportMessage[] @relation("MessageSender")

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLoginAt      DateTime?

  @@index([email])
  @@index([googleId])
}

// ============= SHOP =============
model Shop {
  id             String   @id @default(cuid())
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name           String
  slug           String   @unique
  customDomain   String?  @unique

  tagline        String?
  description    String?
  category       String?
  email          String?
  phone          String?
  address        String?
  whatsappNumber String?
  contactEmail   String?
  city           String?
  country        String?
  instagramUrl   String?
  facebookUrl    String?

  // Apparence
  themeId           String   @default("minimal")
  primaryColor      String   @default("#E84B1F")
  secondaryColor    String?
  accentColor       String?
  bgColor           String   @default("#FAFAF7")
  textColor         String   @default("#0E1116")
  displayFont       String   @default("Fraunces")
  bodyFont          String   @default("Inter")
  backgroundStyle String?  @default("ivory") // ivory | white | cream
  fontStyle       String?  @default("classic") // classic | modern | editorial
  logoUrl         String?
  faviconUrl      String?
  ogImageUrl      String?
  heroTemplate    String?  @default("universal") @map("hero_template")
  heroImageUrl    String?  @map("hero_image_url") @db.Text
  heroImageGeneratedAt DateTime? @map("hero_image_generated_at")
  heroImageGenerations Int       @default(0) @map("hero_image_generations")
  heroImagePrompt      String?   @map("hero_image_prompt") @db.Text
  headerStyle          String?   @default("centered") @map("header_style")
  productGridCols      Int?      @default(3) @map("product_grid_cols")
  footerStyle          String?   @default("classic") @map("footer_style")
  heroStyle            String?   @default("image-text") @map("hero_style")
  mobileLogoUrl        String?   @map("mobile_logo_url")
  customDomainVerifiedAt DateTime? @map("custom_domain_verified_at")

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // Tracking
  fbPixelId       String?
  fbCapiToken     String?
  ga4MeasurementId String?
  tiktokPixelId   String?
  snapPixelId     String?

  // Status
  isPublished    Boolean  @default(false)
  status         String   @default("SETUP") // SETUP, ACTIVE, MAINTENANCE
  plan           String   @default("free") // free, pro, business
  planActivatedAt DateTime?
  planExpiresAt   DateTime?
  proSince             DateTime? @map("pro_since")
  businessSince        DateTime? @map("business_since")
  planRenewalAt        DateTime? @map("plan_renewal_at")

  cartevoPayinBalance     Decimal?  @map("cartevo_payin_balance") @db.Decimal(15, 2)
  cartevoPayoutBalance    Decimal?  @map("cartevo_payout_balance") @db.Decimal(15, 2)
  cartevoBalanceUpdatedAt DateTime? @map("cartevo_balance_updated_at")

  codEnabled              Boolean   @default(false) @map("cod_enabled")
  codCommissionRate       Float     @default(0) @map("cod_commission_rate")
  currency       String   @default("XAF")
  views          Int      @default(0)
  publishedAt    DateTime?

  // Retrait marchand (Mobile Money)
  payoutPhone       String?  @map("payout_phone")
  payoutOperator    String?  @map("payout_operator")
  payoutCountry     String?  @map("payout_country")
  payoutHolderName  String?  @map("payout_holder_name")

  // Livraison & paiement
  shippingZones           Json?   // Array<{ id, name, price, eta }>
  paymentCashOnDelivery  Boolean @default(true)
  paymentOnlineEscrow   Boolean @default(true)

  products       Product[]
  orders         Order[]
  customers      Customer[]
  reviews        Review[]
  cartevoTransactions CartevoTransaction[]
  payouts             Payout[]
  coupons             Coupon[]
  giftCards           GiftCard[]
  flashCampaigns      FlashCampaign[]
  loyaltyAccounts     LoyaltyAccount[]
  loyaltyConfig       LoyaltyConfig?
  shopPages           ShopPage[]
  shopFaqs            ShopFaq[]
  featureUnlocks      ShopFeatureUnlock[]
  productReports      ProductReport[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([status])
}

model Product {
  id               String   @id @default(cuid())
  shopId           String
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Identité
  name             String
  slug             String?
  description      String?  @db.Text
  shortDescription String?
  emoji            String?

  // Prix
  price            Int
  comparePrice     Int?
  currency         String   @default("XAF")

  // Catégorisation
  category        String?
  customCategory String?
  tags           String[] @default([])

  // Type & inventaire
  type            String   @default("physical")
  sku             String?
  stock           Int?
  unlimitedStock  Boolean @default(true)
  weight          Int?

  // Compteur d'urgence (promo)
  promoEndsAt     DateTime?

  // Digital uniquement
  digitalFileUrl String?  @db.Text
  downloadLimit  Int?

  // Visuel
  imageUrl    String?  @db.Text
  galleryUrls Json?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Variantes (physique uniquement)
  hasVariants   Boolean  @default(false)
  variantAxes   Json?    // [{ name, values, swatches? }]
  variants      ProductVariant[]

  feeMode              String   @default("merchant_absorbs") @map("fee_mode")
  codAvailable         Boolean  @default(false) @map("cod_available")

  // Statut
  status      String   @default("active")
  position    Int      @default(0)
  views       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]
  reports     ProductReport[]

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([status])
  @@index([category])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  attributes  Json     // { "Taille": "M", "Couleur": "Bleu" }
  label       String   // "Bleu / M"

  stock       Int?     // null = hérite du Product.stock
  priceDelta  Int      @default(0) // prix final = Product.price + priceDelta
  imageUrl    String?
  sku         String?

  isActive    Boolean  @default(true)
  position    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([productId, isActive])
}

// ============= SESSION =============
model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String   @unique
  ipAddress    String?
  userAgent    String?
  device       String?
  location     String?

  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============= VERIFICATION TOKEN (OTP) =============
model VerificationToken {
  id         String    @id @default(cuid())
  email      String
  code       String
  type       String    @default("EMAIL_VERIFICATION") // EMAIL_VERIFICATION, PASSWORD_RESET
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, code])
  @@index([email, type])
}

model TrustedDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token       String   @unique
  fingerprint String
  device      String?
  location    String?
  ipAddress   String?

  expiresAt   DateTime
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============= PASSWORD RESET TOKEN =============
model PasswordResetToken {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([token])
  @@index([email])
}

// ============= DRAFT SHOP — Boutique générée par IA en attente de claim =============
model DraftShop {
  id              String   @id @default(cuid())

  // Input utilisateur
  prompt          String   @db.Text
  shopName        String

  // Statut de génération
  status          String   @default("pending")  // pending, ready, failed
  errorMessage    String?  @db.Text

  // Output IA (stocké en JSON)
  generatedData   Json?

  // Métadonnées
  ipAddress       String?

  // Liaison user après inscription
  userId          String?
  claimedAt       DateTime?
  consumedAt      DateTime?

  createdAt       DateTime @default(now())
  expiresAt       DateTime  // TTL 24h

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// ============= ORDER (commandes boutique publique) =============
model Order {
  id                String    @id @default(cuid())
  shopId            String
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  orderNumber       String    @unique

  customerName      String
  customerPhone     String
  customerEmail     String?
  customerCity      String?
  customerAddress   String?
  customerNotes     String?   @db.Text

  items             Json
  subtotal          Int
  shippingPrice     Int       @default(0)
  shippingZone      String?
  shippingEta       String?
  total             Int

  paymentMethod     String
  paymentSubMethod  String?
  paymentProvider   String?
  paymentStatus     String    @default("pending")

  operatorFee       Int       @default(0) @map("operator_fee")

  qrCode            String?   @unique
  qrScannedAt       DateTime?

  deliveryCode        String?   @map("delivery_code")
  deliveryConfirmedAt DateTime? @map("delivery_confirmed_at")

  status            String    @default("pending")

  whatsappContacted Boolean   @default(false)

  paidAt            DateTime?
  refundedAt        DateTime?
  refundDeadline    DateTime?

  notifiedAt           DateTime? @map("notified_at")
  notifiedAdminAt      DateTime? @map("notified_admin_at")
  feeMode              String    @default("merchant_absorbs") @map("fee_mode")

  couponCode            String?  @map("coupon_code")
  couponDiscount        Int?     @map("coupon_discount")
  giftCardCode          String?  @map("gift_card_code")
  giftCardAmount        Int?     @map("gift_card_amount")
  flashCampaignId       String?  @map("flash_campaign_id")
  loyaltyPointsRedeemed Int?     @map("loyalty_points_redeemed")
  loyaltyPointsEarned   Int?     @map("loyalty_points_earned")

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  confirmedAt       DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?

  cartevoTransaction CartevoTransaction? @relation("OrderCartevoTx")
  payouts            Payout[]

  @@index([shopId])
  @@index([orderNumber])
  @@index([qrCode])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model Customer {
  id            String    @id @default(cuid())
  shopId        String    @map("shop_id")
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  email         String?
  phone         String
  fullName      String    @map("full_name")

  city          String?
  address       String?

  totalOrders   Int       @default(0) @map("total_orders")
  totalSpent    Int       @default(0) @map("total_spent")
  averageOrder  Int       @default(0) @map("average_order")

  firstOrderAt  DateTime? @map("first_order_at")
  lastOrderAt   DateTime? @map("last_order_at")

  tags          String[]  @default([])
  notes         String?   @db.Text

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@unique([shopId, phone])
  @@index([shopId, lastOrderAt])
  @@map("customers")
}

// ============================================
// CARTEVO PAYMENT INTEGRATION
// ============================================

/// Transaction Cartevo (collecte client OU payout marchand)
model CartevoTransaction {
  id                String   @id @default(cuid())

  cartevoTxId       String   @unique @map("cartevo_tx_id")
  cartevoExternalId String?  @map("cartevo_external_id")

  type              CartevoTxType
  status            CartevoTxStatus @default(INITIATED)

  amount            Decimal  @db.Decimal(14, 2)
  currency          String
  feeCartevo        Decimal  @default(0) @db.Decimal(14, 2) @map("fee_cartevo")
  feeSellia         Decimal  @default(0) @db.Decimal(14, 2) @map("fee_sellia")
  netAmount         Decimal  @default(0) @db.Decimal(14, 2) @map("net_amount")
  cartevoRate       Float    @default(0) @map("cartevo_rate")
  selliaRate        Float    @default(0) @map("sellia_rate")
  shopPlanAtTime    String   @default("free") @map("shop_plan_at_time")
  feeMode           String   @default("merchant_absorbs") @map("fee_mode_snapshot")

  operator          String
  country           String
  phoneNumber       String   @map("phone_number")

  shopId            String?  @map("shop_id")
  shop              Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  orderId           String?  @unique @map("order_id")
  order             Order?   @relation("OrderCartevoTx", fields: [orderId], references: [id], onDelete: SetNull)
  payoutId          String?  @unique @map("payout_id")
  payout            Payout?  @relation("PayoutCartevoTx", fields: [payoutId], references: [id], onDelete: SetNull)

  errorMessage      String?  @map("error_message") @db.Text
  rawRequest        Json?    @map("raw_request")
  rawResponse       Json?    @map("raw_response")

  payinBalanceBefore   Decimal?  @map("payin_balance_before") @db.Decimal(15, 2)
  payinBalanceAfter    Decimal?  @map("payin_balance_after") @db.Decimal(15, 2)
  balanceMatchedAt     DateTime? @map("balance_matched_at")
  balanceMatchAttempts Int       @default(0) @map("balance_match_attempts")
  balanceMatchSource   String?   @map("balance_match_source")

  initiatedAt       DateTime @default(now()) @map("initiated_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([shopId, type, status])
  @@index([cartevoTxId])
  @@index([createdAt])
  @@map("cartevo_transactions")
}

model Payout {
  id              String   @id @default(cuid())

  shopId          String   @map("shop_id")
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  payoutType      PayoutType @default(MERCHANT_REQUESTED) @map("payout_type")
  orderId         String?  @map("order_id")
  order           Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  amount          Decimal  @db.Decimal(14, 2)
  grossAmount     Decimal? @db.Decimal(14, 2) @map("gross_amount")
  commissionRate  Decimal? @db.Decimal(5, 2) @map("commission_rate")
  commissionAmount Decimal? @db.Decimal(14, 2) @map("commission_amount")
  feeCartevo      Decimal  @default(0) @db.Decimal(14, 2) @map("fee_cartevo")
  netAmount       Decimal  @db.Decimal(14, 2) @map("net_amount")
  currency        String   @default("XAF")

  operator        String
  country         String
  phoneNumber     String   @map("phone_number")

  status          PayoutStatus @default(PENDING)

  version         Int          @default(0)

  cartevoTx       CartevoTransaction? @relation("PayoutCartevoTx")

  releasedAt      DateTime? @map("released_at")
  paidOutAt       DateTime? @map("paid_out_at")
  description     String?  @db.Text

  errorMessage    String?  @map("error_message") @db.Text
  requestedAt     DateTime @default(now()) @map("requested_at")
  processedAt     DateTime? @map("processed_at")
  completedAt     DateTime? @map("completed_at")

  withdrawalGroupId    String?   @map("withdrawal_group_id")
  withdrawalGrossAmount Decimal? @map("withdrawal_gross_amount") @db.Decimal(14, 2)
  withdrawalNetAmount   Decimal? @map("withdrawal_net_amount") @db.Decimal(14, 2)
  cartevoTxId           String?   @map("cartevo_tx_id")
  reviewedBy            String?   @map("reviewed_by")
  reviewedAt            DateTime? @map("reviewed_at")
  rejectionReason       String?   @map("rejection_reason") @db.Text
  manualReviewRequired  Boolean   @default(false) @map("manual_review_required")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([orderId, payoutType])
  @@index([shopId, status])
  @@index([shopId, releasedAt])
  @@index([withdrawalGroupId])
  @@index([cartevoTxId])
  @@index([createdAt])
  @@map("payouts")
}

model CartevoWebhookLog {
  id               String   @id @default(cuid())

  webhookId        String   @unique @map("webhook_id")

  event            String
  cartevoTxId      String?  @map("cartevo_tx_id")

  processed        Boolean  @default(false)
  processedAt      DateTime? @map("processed_at")
  errorMessage     String?  @map("error_message") @db.Text

  retryCount       Int      @default(0) @map("retry_count")
  nextRetryAt      DateTime? @map("next_retry_at")
  lastRetryAt      DateTime? @map("last_retry_at")

  rawHeaders       Json     @map("raw_headers")
  rawBody          Json     @map("raw_body")
  signatureValid   Boolean  @default(false) @map("signature_valid")
  receivedAt       DateTime @default(now()) @map("received_at")

  @@index([cartevoTxId])
  @@index([receivedAt])
  @@index([processed, nextRetryAt])
  @@map("cartevo_webhook_logs")
}

enum CartevoTxType {
  COLLECT
  PAYOUT
}

enum CartevoTxStatus {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  CANCELLED
}

enum PayoutType {
  ORDER_DIGITAL
  ORDER_PHYSICAL
  ORDER_SERVICE
  MERCHANT_REQUESTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  PENDING_ESCROW
  AVAILABLE
  REQUESTED
  PAID
  REFUNDED
}

model Review {
  id              String    @id @default(cuid())
  shopId          String
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  authorName      String
  authorEmail     String?

  rating          Int
  title           String?   @db.Text
  content         String    @db.Text

  status          String    @default("pending")
  rejectionReason String?

  createdAt       DateTime  @default(now())
  approvedAt      DateTime?

  @@index([shopId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// G2.2.E — PROMOTIONS
// ============================================================================

model Coupon {
  id                   String       @id @default(cuid())
  shopId               String       @map("shop_id")
  shop                 Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  code                 String
  name                 String
  description          String?      @db.Text

  discountType         DiscountType
  discountValue        Int

  minOrderAmount       Int?         @map("min_order_amount")
  maxDiscount          Int?         @map("max_discount")

  startsAt             DateTime     @map("starts_at")
  endsAt               DateTime?    @map("ends_at")

  maxUses              Int?         @map("max_uses")
  maxUsesPerCustomer   Int?         @default(1) @map("max_uses_per_customer")
  currentUses          Int          @default(0) @map("current_uses")

  isActive             Boolean      @default(true) @map("is_active")
  firstOrderOnly       Boolean      @default(false) @map("first_order_only")
  applicableProductIds String[]     @default([]) @map("applicable_product_ids")

  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  usages               CouponUsage[]

  @@unique([shopId, code])
  @@index([shopId, isActive])
  @@map("coupons")
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model CouponUsage {
  id              String   @id @default(cuid())
  couponId        String   @map("coupon_id")
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  orderId         String?  @map("order_id")
  customerPhone   String   @map("customer_phone")
  discountAmount  Int      @map("discount_amount")

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([couponId, customerPhone])
  @@map("coupon_usages")
}

model GiftCard {
  id              String   @id @default(cuid())
  shopId          String   @map("shop_id")
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  code            String   @unique
  initialAmount   Int      @map("initial_amount")
  remainingAmount Int      @map("remaining_amount")

  buyerName       String?  @map("buyer_name")
  buyerPhone      String?  @map("buyer_phone")
  recipientName   String?  @map("recipient_name")
  recipientPhone  String?  @map("recipient_phone")
  message         String?  @db.Text

  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean  @default(true) @map("is_active")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  transactions    GiftCardTransaction[]

  @@index([shopId, isActive])
  @@map("gift_cards")
}

model GiftCardTransaction {
  id           String   @id @default(cuid())
  giftCardId   String   @map("gift_card_id")
  giftCard     GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  amount       Int
  orderId      String?  @map("order_id")
  balanceAfter Int      @map("balance_after")

  createdAt    DateTime @default(now()) @map("created_at")

  @@map("gift_card_transactions")
}

model FlashCampaign {
  id            String       @id @default(cuid())
  shopId        String       @map("shop_id")
  shop          Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  name          String
  description   String?      @db.Text

  discountType  DiscountType
  discountValue Int

  startsAt      DateTime     @map("starts_at")
  endsAt        DateTime     @map("ends_at")

  productIds    String[]     @default([]) @map("product_ids")

  isActive      Boolean      @default(true) @map("is_active")

  ordersCount   Int          @default(0) @map("orders_count")
  totalDiscount Int          @default(0) @map("total_discount")

  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([shopId, isActive, startsAt, endsAt])
  @@map("flash_campaigns")
}

model LoyaltyAccount {
  id              String      @id @default(cuid())
  shopId          String      @map("shop_id")
  shop            Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerId      String?     @map("customer_id")
  customerPhone   String      @map("customer_phone")
  customerName    String      @map("customer_name")

  points          Int         @default(0)
  lifetimePoints  Int         @default(0) @map("lifetime_points")

  tier            LoyaltyTier @default(BRONZE)

  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  transactions    LoyaltyTransaction[]

  @@unique([shopId, customerPhone])
  @@index([shopId, tier])
  @@map("loyalty_accounts")
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model LoyaltyTransaction {
  id          String         @id @default(cuid())
  accountId   String         @map("account_id")
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  type        LoyaltyTxnType
  points      Int
  orderId     String?        @map("order_id")
  description String?

  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("loyalty_transactions")
}

enum LoyaltyTxnType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
}

model LoyaltyConfig {
  id                       String   @id @default(cuid())
  shopId                   String   @unique @map("shop_id")
  shop                     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  isEnabled                Boolean  @default(false) @map("is_enabled")

  pointsPerCurrency        Int      @default(1) @map("points_per_currency")
  currencyPerPoint         Int      @default(100) @map("currency_per_point")

  redemptionPointsRequired Int      @default(100) @map("redemption_points_required")
  redemptionDiscountAmount Int      @default(500) @map("redemption_discount_amount")

  silverThreshold          Int      @default(500) @map("silver_threshold")
  goldThreshold            Int      @default(2000) @map("gold_threshold")
  platinumThreshold        Int      @default(5000) @map("platinum_threshold")

  welcomeBonusPoints       Int      @default(0) @map("welcome_bonus_points")

  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  @@map("loyalty_configs")
}

model ShopPage {
  id              String   @id @default(cuid())
  shopId          String   @map("shop_id")
  shop            Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  slug            String
  title           String
  content         String   @db.Text
  metaDescription String?  @map("meta_description")

  isPublished     Boolean  @default(true) @map("is_published")
  showInHeader    Boolean  @default(false) @map("show_in_header")
  showInFooter    Boolean  @default(true) @map("show_in_footer")

  templateKey     String?  @map("template_key")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([shopId, slug])
  @@index([shopId, isPublished])
  @@map("shop_pages")
}

model ShopFaq {
  id          String   @id @default(cuid())
  shopId      String   @map("shop_id")
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  question    String   @db.Text
  answer      String   @db.Text
  category    String?

  order       Int      @default(0)
  isPublished Boolean  @default(true) @map("is_published")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([shopId, isPublished, order])
  @@map("shop_faqs")
}

// ============================================
// SUPPORT TICKETS (G3.0.B)
// ============================================

enum TicketStatus {
  OPEN
  WAITING_USER
  WAITING_SUPPORT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  TECHNICAL
  ORDER
  PAYMENT
  SHOP
  SUGGESTION
  OTHER
}

enum SenderType {
  MERCHANT
  SUPPORT
  SYSTEM
}

model SupportTicket {
  id              String          @id @default(cuid())

  userId          String
  user            User            @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)

  shopId          String?
  shopName        String?
  shopSlug        String?

  subject         String          @db.VarChar(200)
  category        TicketCategory  @default(OTHER)
  priority        TicketPriority  @default(NORMAL)
  status          TicketStatus    @default(OPEN)

  lastMessageAt   DateTime        @default(now())
  lastMessageBy   SenderType      @default(MERCHANT)

  unreadByUser    Int             @default(0)
  unreadBySupport Int             @default(1)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  resolvedAt      DateTime?
  closedAt        DateTime?

  messages        SupportMessage[]

  @@index([userId, status])
  @@index([status, lastMessageAt])
  @@index([createdAt])
  @@map("support_tickets")
}

model SupportMessage {
  id              String          @id @default(cuid())

  ticketId        String
  ticket          SupportTicket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId        String?
  sender          User?           @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  senderType      SenderType
  senderName      String

  content         String          @db.Text
  attachments     String[]        @default([])

  readAt          DateTime?
  createdAt       DateTime        @default(now())

  @@index([ticketId, createdAt])
  @@index([senderId])
  @@map("support_messages")
}

// ============================================
// SHOP FEATURE UNLOCKS (G3.0.B.1)
// ============================================

enum FeatureCode {
  COD
}

model ShopFeatureUnlock {
  id              String         @id @default(cuid())

  shopId          String
  shop            Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)

  feature         FeatureCode

  unlockedAt      DateTime       @default(now())
  paidAmount      Int
  paymentMethod   String?
  paymentRef      String?

  createdAt       DateTime       @default(now())

  @@unique([shopId, feature])
  @@index([shopId])
  @@map("shop_feature_unlocks")
}

// ============================================================================
// G6 — SIGNALEMENTS PRODUITS
// ============================================================================

enum ReportReason {
  COUNTERFEIT      // Contrefaçon
  INAPPROPRIATE    // Contenu inapproprié
  MISLEADING       // Description trompeuse
  SCAM             // Arnaque / fraude
  PROHIBITED       // Produit interdit
  OTHER            // Autre
}

enum ReportStatus {
  PENDING
  REVIEWING
  RESOLVED
  DISMISSED
}

model ProductReport {
  id            String        @id @default(cuid())

  shopId        String
  shop          Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)

  productId     String
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  reason        ReportReason
  description   String        @db.Text

  reporterName  String?
  reporterEmail String?

  status        ReportStatus  @default(PENDING)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([shopId])
  @@index([productId])
  @@index([status])
  @@map("product_reports")
}

/// Réglages opérationnels plateforme (une ligne id = "default").
model PlatformSettings {
  id                    String   @id @default("default")

  maintenanceMode       Boolean  @default(false) @map("maintenance_mode")
  maintenanceMessage    String?  @map("maintenance_message") @db.Text
  registrationsOpen     Boolean  @default(true) @map("registrations_open")
  shopCreationOpen      Boolean  @default(true) @map("shop_creation_open")
  merchantBannerEnabled Boolean  @default(false) @map("merchant_banner_enabled")
  merchantBannerMessage String?  @map("merchant_banner_message") @db.Text
  supportEmail          String?  @map("support_email")
  supportPhone          String?  @map("support_phone")
  adminNotifyEmail      String?  @map("admin_notify_email")

  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
