generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= USER =============
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  passwordHash     String

  firstName        String?
  lastName         String?
  phone            String?
  country          String?   @default("CM")
  city             String?
  avatarUrl        String?
  bio              String?

  twoFactorEnabled Boolean   @default(false)

  shops            Shop[]
  sessions         Session[]
  trustedDevices   TrustedDevice[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLoginAt      DateTime?

  @@index([email])
}

// ============= SHOP =============
model Shop {
  id             String   @id @default(cuid())
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name           String
  slug           String   @unique
  customDomain   String?  @unique

  tagline        String?
  description    String?
  email          String?
  phone          String?
  address        String?

  // Apparence
  themeId        String   @default("minimal")
  primaryColor   String   @default("#E84B1F")
  bgColor        String   @default("#FAFAF7")
  textColor      String   @default("#0E1116")
  displayFont    String   @default("Fraunces")
  bodyFont       String   @default("Inter")
  logoUrl        String?
  faviconUrl     String?
  ogImageUrl     String?

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // Tracking
  fbPixelId       String?
  fbCapiToken     String?
  ga4MeasurementId String?
  tiktokPixelId   String?
  snapPixelId     String?

  // Status
  isPublished    Boolean  @default(false)
  status         String   @default("SETUP") // SETUP, ACTIVE, MAINTENANCE
  plan           String   @default("DECOUVERTE") // DECOUVERTE, PRO

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
}

// ============= SESSION =============
model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String   @unique
  ipAddress    String?
  userAgent    String?
  device       String?
  location     String?

  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============= VERIFICATION TOKEN (OTP) =============
model VerificationToken {
  id         String    @id @default(cuid())
  email      String
  code       String
  type       String    @default("EMAIL_VERIFICATION") // EMAIL_VERIFICATION, PASSWORD_RESET
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, code])
  @@index([email, type])
}

model TrustedDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token       String   @unique
  fingerprint String
  device      String?
  location    String?
  ipAddress   String?

  expiresAt   DateTime
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============= PASSWORD RESET TOKEN =============
model PasswordResetToken {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([token])
  @@index([email])
}
