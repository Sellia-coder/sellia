generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============= USER =============
model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  passwordHash     String?

  googleId         String?   @unique
  authProvider     String    @default("email")

  firstName        String?
  lastName         String?
  phone            String?
  country          String?   @default("CM")
  city             String?
  avatarUrl        String?
  bio              String?

  twoFactorEnabled Boolean   @default(false)
  onboardingCompleted Boolean @default(false)

  shops            Shop[]
  sessions         Session[]
  trustedDevices   TrustedDevice[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  lastLoginAt      DateTime?

  @@index([email])
  @@index([googleId])
}

// ============= SHOP =============
model Shop {
  id             String   @id @default(cuid())
  ownerId        String
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name           String
  slug           String   @unique
  customDomain   String?  @unique

  tagline        String?
  description    String?
  category       String?
  email          String?
  phone          String?
  address        String?
  whatsappNumber String?
  contactEmail   String?
  city           String?
  country        String?
  instagramUrl   String?
  facebookUrl    String?

  // Apparence
  themeId           String   @default("minimal")
  primaryColor      String   @default("#E84B1F")
  secondaryColor    String?
  accentColor       String?
  bgColor           String   @default("#FAFAF7")
  textColor         String   @default("#0E1116")
  displayFont       String   @default("Fraunces")
  bodyFont          String   @default("Inter")
  backgroundStyle String?  @default("ivory") // ivory | white | cream
  fontStyle       String?  @default("classic") // classic | modern | editorial
  logoUrl         String?
  faviconUrl      String?
  ogImageUrl      String?

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  // Tracking
  fbPixelId       String?
  fbCapiToken     String?
  ga4MeasurementId String?
  tiktokPixelId   String?
  snapPixelId     String?

  // Status
  isPublished    Boolean  @default(false)
  status         String   @default("SETUP") // SETUP, ACTIVE, MAINTENANCE
  plan           String   @default("free") // free, pro
  planActivatedAt DateTime?
  planExpiresAt   DateTime?
  currency       String   @default("XAF")
  views          Int      @default(0)
  publishedAt    DateTime?

  // Livraison & paiement
  shippingZones           Json?   // Array<{ id, name, price, eta }>
  paymentCashOnDelivery  Boolean @default(true)
  paymentOnlineEscrow   Boolean @default(true)

  products       Product[]
  orders         Order[]
  reviews        Review[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([status])
}

model Product {
  id               String   @id @default(cuid())
  shopId           String
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Identité
  name             String
  slug             String?
  description      String?  @db.Text
  shortDescription String?
  emoji            String?

  // Prix
  price            Int
  comparePrice     Int?
  currency         String   @default("XAF")

  // Catégorisation
  category        String?
  customCategory String?
  tags           String[] @default([])

  // Type & inventaire
  type            String   @default("physical")
  sku             String?
  stock           Int?
  unlimitedStock  Boolean @default(true)
  weight          Int?

  // Compteur d'urgence (promo)
  promoEndsAt     DateTime?

  // Digital uniquement
  digitalFileUrl String?  @db.Text
  downloadLimit  Int?

  // Visuel
  imageUrl    String?  @db.Text
  galleryUrls Json?

  // SEO
  metaTitle       String?
  metaDescription String?

  // Variantes (physique uniquement)
  hasVariants   Boolean  @default(false)
  variantAxes   Json?    // [{ name, values, swatches? }]
  variants      ProductVariant[]

  // Statut
  status      String   @default("active")
  position    Int      @default(0)
  views       Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]

  @@unique([shopId, slug])
  @@index([shopId])
  @@index([status])
  @@index([category])
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  attributes  Json     // { "Taille": "M", "Couleur": "Bleu" }
  label       String   // "Bleu / M"

  stock       Int?     // null = hérite du Product.stock
  priceDelta  Int      @default(0) // prix final = Product.price + priceDelta
  imageUrl    String?
  sku         String?

  isActive    Boolean  @default(true)
  position    Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([productId, isActive])
}

// ============= SESSION =============
model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token        String   @unique
  ipAddress    String?
  userAgent    String?
  device       String?
  location     String?

  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============= VERIFICATION TOKEN (OTP) =============
model VerificationToken {
  id         String    @id @default(cuid())
  email      String
  code       String
  type       String    @default("EMAIL_VERIFICATION") // EMAIL_VERIFICATION, PASSWORD_RESET
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, code])
  @@index([email, type])
}

model TrustedDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token       String   @unique
  fingerprint String
  device      String?
  location    String?
  ipAddress   String?

  expiresAt   DateTime
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// ============= PASSWORD RESET TOKEN =============
model PasswordResetToken {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([token])
  @@index([email])
}

// ============= DRAFT SHOP — Boutique générée par IA en attente de claim =============
model DraftShop {
  id              String   @id @default(cuid())

  // Input utilisateur
  prompt          String   @db.Text
  shopName        String

  // Statut de génération
  status          String   @default("pending")  // pending, ready, failed
  errorMessage    String?  @db.Text

  // Output IA (stocké en JSON)
  generatedData   Json?

  // Métadonnées
  ipAddress       String?

  // Liaison user après inscription
  userId          String?
  claimedAt       DateTime?
  consumedAt      DateTime?

  createdAt       DateTime @default(now())
  expiresAt       DateTime  // TTL 24h

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

// ============= ORDER (commandes boutique publique) =============
model Order {
  id                String    @id @default(cuid())
  shopId            String
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  orderNumber       String    @unique

  customerName      String
  customerPhone     String
  customerEmail     String?
  customerCity      String?
  customerAddress   String?
  customerNotes     String?   @db.Text

  items             Json
  subtotal          Int
  shippingPrice     Int       @default(0)
  shippingZone      String?
  shippingEta       String?
  total             Int

  paymentMethod     String
  paymentSubMethod  String?
  paymentProvider   String?
  paymentStatus     String    @default("pending")

  qrCode            String?   @unique
  qrScannedAt       DateTime?

  status            String    @default("pending")

  whatsappContacted Boolean   @default(false)

  paidAt            DateTime?
  refundedAt        DateTime?
  refundDeadline    DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  confirmedAt       DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?

  @@index([shopId])
  @@index([orderNumber])
  @@index([qrCode])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model Review {
  id              String    @id @default(cuid())
  shopId          String
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  authorName      String
  authorEmail     String?

  rating          Int
  title           String?   @db.Text
  content         String    @db.Text

  status          String    @default("pending")
  rejectionReason String?

  createdAt       DateTime  @default(now())
  approvedAt      DateTime?

  @@index([shopId])
  @@index([productId])
  @@index([status])
  @@index([createdAt])
}
